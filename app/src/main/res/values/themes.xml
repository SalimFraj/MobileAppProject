<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base App Theme -->
    <style name="Theme.HouseKeep" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.HouseKeep.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#6366F1</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.HouseKeep</item>
    </style>
    
    <!-- Dark Theme (for Theme.HouseKeep if needed by OS) -->
    <style name="Theme.HouseKeep.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>